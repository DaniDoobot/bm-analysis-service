# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Azure OpenAI (Exclusivo) ──────────────────────────────────────────────────
AZURE_OPENAI_API_VERSION=2025-01-01-preview

AZURE_OPENAI_TEXT_ENDPOINT=https://xxxxx-text.openai.azure.com/
AZURE_OPENAI_TEXT_API_KEY=
AZURE_OPENAI_TEXT_DEPLOYMENT=gpt-4-deployment

AZURE_OPENAI_AUDIO_ENDPOINT=https://xxxxx-audio.openai.azure.com/
AZURE_OPENAI_AUDIO_API_KEY=
AZURE_OPENAI_AUDIO_DEPLOYMENT=gpt-4o-audio-deployment

AZURE_OPENAI_TRANSCRIPTION_ENDPOINT=https://xxxxx-transcription.openai.azure.com/
AZURE_OPENAI_TRANSCRIPTION_API_KEY=
AZURE_OPENAI_TRANSCRIPTION_DEPLOYMENT=whisper-deployment

# ── HubSpot ───────────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_ANALYSIS_MODEL=gemini-3-flash-preview
GEMINI_REPORT_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=0.2
GEMINI_TIMEOUT_SECONDS=120
AI_PROVIDER=gemini

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all (dev only).
# Example: https://yourapp.lovable.app,http://localhost:5173
CORS_ORIGINS=*
